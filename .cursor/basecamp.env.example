# Copy to basecamp.env and fill in (never commit basecamp.env — it is gitignored).
# Get an OAuth app + tokens at https://integrate.37signals.com/ (Basecamp 2 / Launchpad).
#
# BASECAMP_TOKEN expires every ~2 weeks. Refresh it with:
#   ./.cursor/refresh-basecamp-token.sh
# (needs CLIENT_ID / CLIENT_SECRET / REFRESH_TOKEN below).

BASECAMP_TOKEN=BAhbB0ki...
BASECAMP_ACCOUNT_ID=1757560
BASECAMP_USER_AGENT=you@example.com

# Required only for automatic token refresh:
BASECAMP_CLIENT_ID=your_oauth_app_client_id
BASECAMP_CLIENT_SECRET=your_oauth_app_client_secret
BASECAMP_REFRESH_TOKEN=BAhbB0ki...
